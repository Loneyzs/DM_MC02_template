/dts-v1/;
#include <st/h7/stm32h723Xg.dtsi>
#include <st/h7/stm32h723zgtx-pinctrl.dtsi>
#include <zephyr/dt-bindings/flash_controller/ospi.h>
#include <zephyr/dt-bindings/input/input-event-codes.h>
#include <zephyr/dt-bindings/led/led.h>

/ {
	model = "Damiao DM-MC-Board02";
	compatible = "damiao,dm-mc02";

	chosen {
		/* Console is selected by Kconfig as SEGGER RTT. */
		zephyr,dtcm = &dtcm;
		zephyr,sram = &sram0;
		zephyr,flash = &flash0;
		zephyr,canbus = &fdcan1;
	};

	keys: gpio_keys {
		compatible = "gpio-keys";

		user_button: user_button {
			label = "User Key";
			gpios = <&gpioa 15 GPIO_ACTIVE_LOW>;
			zephyr,code = <INPUT_KEY_0>;
		};

		lcd_button: lcd_button {
			label = "LCD Key";
			gpios = <&gpioa 5 GPIO_ACTIVE_LOW>;
			zephyr,code = <INPUT_KEY_1>;
		};
	};

	power_outputs: power_outputs {
		compatible = "gpio-leds";

		power_out1_en: power_out1_en {
			gpios = <&gpioc 14 GPIO_ACTIVE_HIGH>;
			label = "Power OUT1 enable";
		};

		power_out2_en: power_out2_en {
			gpios = <&gpioc 13 GPIO_ACTIVE_HIGH>;
			label = "Power OUT2 enable";
		};

		power_5v_en: power_5v_en {
			gpios = <&gpioc 15 GPIO_ACTIVE_HIGH>;
			label = "External 5V enable";
		};
	};

	pwm_outputs: pwm_outputs {
		compatible = "pwm-leds";

		buzzer_pwm: buzzer_pwm {
			pwms = <&pwm12 2 PWM_USEC(250) PWM_POLARITY_NORMAL>;
			label = "Buzzer";
		};

		imu_heater_pwm: imu_heater_pwm {
			/*
			 * The schematic and pinout diagram mark PB1 as TIM3_CH4.
			 * A secondary markdown summary says TIM8_CH4, which does
			 * not match the primary hardware documents.
			 */
			pwms = <&pwm3 4 PWM_MSEC(10) PWM_POLARITY_NORMAL>;
			label = "IMU heater";
		};

		pwm1_out: pwm1_out {
			pwms = <&pwm2 1 PWM_MSEC(20) PWM_POLARITY_NORMAL>;
			label = "PWM1";
		};

		pwm2_out: pwm2_out {
			pwms = <&pwm2 3 PWM_MSEC(20) PWM_POLARITY_NORMAL>;
			label = "PWM2";
		};

		pwm3_out: pwm3_out {
			pwms = <&pwm1 1 PWM_MSEC(20) PWM_POLARITY_NORMAL>;
			label = "PWM3";
		};

		pwm4_out: pwm4_out {
			pwms = <&pwm1 3 PWM_MSEC(20) PWM_POLARITY_NORMAL>;
			label = "PWM4";
		};
	};

	aliases {
		sw0 = &user_button;
		sw1 = &lcd_button;
		pwm-buzzer = &buzzer_pwm;
		pwm-heater = &imu_heater_pwm;
		pwm-servo1 = &pwm1_out;
		pwm-servo2 = &pwm2_out;
		pwm-servo3 = &pwm3_out;
		pwm-servo4 = &pwm4_out;
		led-strip0 = &ws2812;
		spi-lcd = &spi1;
		spi-imu = &spi2;
		spi-expansion = &spi3;
		i2c-lcd = &i2c2;
		i2c-camera = &i2c1;
		volt-adc = &adc1;
		watchdog0 = &iwdg;
	};
};

&clk_hsi48 {
	status = "okay";
};

&clk_lsi {
	status = "okay";
};

&clk_hse {
	clock-frequency = <DT_FREQ_M(24)>;
	status = "okay";
};

&pll {
	div-m = <6>;
	mul-n = <275>;
	div-p = <2>;
	div-q = <4>;
	div-r = <2>;
	clocks = <&clk_hse>;
	status = "okay";
};

&pll2 {
	div-m = <3>;
	mul-n = <50>;
	div-p = <2>;
	div-q = <6>;
	div-r = <2>;
	clocks = <&clk_hse>;
	status = "okay";
};

&rcc {
	clocks = <&pll>;
	clock-frequency = <DT_FREQ_M(550)>;
	d1cpre = <1>;
	hpre = <2>;
	d1ppre = <2>;
	d2ppre1 = <2>;
	d2ppre2 = <2>;
	d3ppre = <2>;
};

&pwr {
	power-supply = "ldo";
};

&usart1 {
	pinctrl-0 = <&usart1_tx_pa9 &usart1_rx_pa10>;
	pinctrl-names = "default";
	current-speed = <115200>;
	status = "disabled";
};

&usart2 {
	pinctrl-0 = <&usart2_tx_pd5 &usart2_rx_pd6 &usart2_de_pd4>;
	pinctrl-names = "default";
	current-speed = <115200>;
	status = "disabled";
};

&usart3 {
	pinctrl-0 = <&usart3_tx_pd8 &usart3_rx_pd9 &usart3_de_pb14>;
	pinctrl-names = "default";
	current-speed = <115200>;
	status = "disabled";
};

&uart5 {
	pinctrl-0 = <&uart5_rx_pd2>;
	pinctrl-names = "default";
	current-speed = <100000>;
	status = "disabled";
};

&uart7 {
	pinctrl-0 = <&uart7_tx_pe8 &uart7_rx_pe7>;
	pinctrl-names = "default";
	current-speed = <115200>;
	status = "disabled";
};

&uart8 {
	pinctrl-0 = <&uart8_tx_pe1 &uart8_rx_pe0>;
	pinctrl-names = "default";
	current-speed = <115200>;
	status = "disabled";
};

&uart9 {
	pinctrl-0 = <&uart9_tx_pd15 &uart9_rx_pd14>;
	pinctrl-names = "default";
	current-speed = <115200>;
	status = "disabled";
};

&usart10 {
	pinctrl-0 = <&usart10_tx_pe3 &usart10_rx_pe2>;
	pinctrl-names = "default";
	current-speed = <115200>;
	status = "disabled";
};

zephyr_udc0: &usbotg_hs {
	pinctrl-0 = <&usb_otg_hs_dm_pa11 &usb_otg_hs_dp_pa12>;
	pinctrl-names = "default";
	status = "okay";
};

&fdcan1 {
	pinctrl-0 = <&fdcan1_rx_pd0 &fdcan1_tx_pd1>;
	pinctrl-names = "default";
	clocks = <&rcc STM32_CLOCK(APB1_2, 8)>,
		 <&rcc STM32_SRC_PLL2_Q FDCAN_SEL(2)>;
	status = "disabled";
};

&fdcan2 {
	pinctrl-0 = <&fdcan2_rx_pb5 &fdcan2_tx_pb6>;
	pinctrl-names = "default";
	clocks = <&rcc STM32_CLOCK(APB1_2, 8)>,
		 <&rcc STM32_SRC_PLL2_Q FDCAN_SEL(2)>;
	status = "disabled";
};

&fdcan3 {
	pinctrl-0 = <&fdcan3_rx_pd12 &fdcan3_tx_pd13>;
	pinctrl-names = "default";
	clocks = <&rcc STM32_CLOCK(APB1_2, 8)>,
		 <&rcc STM32_SRC_PLL2_Q FDCAN_SEL(2)>;
	status = "disabled";
};

&spi1 {
	pinctrl-0 = <&spi1_sck_pb3 &spi1_miso_pb4 &spi1_mosi_pd7>;
	pinctrl-names = "default";
	cs-gpios = <&gpioe 15 GPIO_ACTIVE_LOW>;
	status = "disabled";
};

&spi2 {
	pinctrl-0 = <&spi2_sck_pb13 &spi2_mosi_pc1 &spi2_miso_pc2_c>;
	pinctrl-names = "default";
	cs-gpios = <&gpioc 0 GPIO_ACTIVE_LOW>,
		   <&gpioc 3 GPIO_ACTIVE_LOW>;
	status = "disabled";

	bmi088_accel: bmi088-accel@0 {
		compatible = "bosch,bmi08x-accel";
		reg = <0>;
		spi-max-frequency = <10000000>;
		int-gpios = <&gpioe 10 GPIO_ACTIVE_HIGH>;
		accel-hz = "800";
		accel-fs = <24>;
		int1-map-io = <0x01>;
		int1-conf-io = <0x0a>;
		int2-map-io = <0x00>;
		int2-conf-io = <0x00>;
		status = "disabled";
	};

	bmi088_gyro: bmi088-gyro@1 {
		compatible = "bosch,bmi08x-gyro";
		reg = <1>;
		spi-max-frequency = <10000000>;
		int-gpios = <&gpioe 12 GPIO_ACTIVE_HIGH>;
		gyro-hz = "1000_116";
		gyro-fs = <2000>;
		int3-4-map-io = <0x01>;
		int3-4-conf-io = <0x01>;
		status = "disabled";
	};
};

&spi3 {
	pinctrl-0 = <&spi3_sck_pc10 &spi3_miso_pc11 &spi3_mosi_pc12>;
	pinctrl-names = "default";
	status = "disabled";
};

&spi6 {
	pinctrl-0 = <&spi6_mosi_pa7>;
	pinctrl-names = "default";
	status = "disabled";

	ws2812: ws2812@0 {
		compatible = "worldsemi,ws2812-spi";
		reg = <0>;
		spi-max-frequency = <6400000>;
		chain-length = <1>;
		spi-one-frame = <0x70>;
		spi-zero-frame = <0x40>;
		color-mapping = <LED_COLOR_ID_GREEN
				 LED_COLOR_ID_RED
				 LED_COLOR_ID_BLUE>;
		reset-delay = <80>;
		status = "disabled";
	};
};

&i2c1 {
	pinctrl-0 = <&i2c1_scl_pb8 &i2c1_sda_pb9>;
	pinctrl-names = "default";
	clock-frequency = <I2C_BITRATE_FAST>;
	status = "disabled";
};

&i2c2 {
	pinctrl-0 = <&i2c2_scl_pb10 &i2c2_sda_pb11>;
	pinctrl-names = "default";
	clock-frequency = <I2C_BITRATE_FAST>;
	status = "disabled";
};

&adc1 {
	pinctrl-0 = <&adc1_inp4_pc4>;
	pinctrl-names = "default";
	status = "disabled";
};

&timers1 {
	status = "disabled";

	pwm1: pwm {
		pinctrl-0 = <&tim1_ch1_pe9 &tim1_ch3_pe13>;
		pinctrl-names = "default";
		status = "disabled";
	};
};

&timers2 {
	status = "disabled";

	pwm2: pwm {
		pinctrl-0 = <&tim2_ch1_pa0 &tim2_ch3_pa2>;
		pinctrl-names = "default";
		status = "disabled";
	};
};

&timers3 {
	status = "disabled";

	pwm3: pwm {
		pinctrl-0 = <&tim3_ch4_pb1>;
		pinctrl-names = "default";
		status = "disabled";
	};
};

&timers12 {
	status = "disabled";

	pwm12: pwm {
		pinctrl-0 = <&tim12_ch2_pb15>;
		pinctrl-names = "default";
		status = "disabled";
	};
};

&octospi1 {
	pinctrl-0 = <&octospim_p1_ncs_pe11 &octospim_p1_clk_pb2
		     &octospim_p1_io0_pd11 &octospim_p1_io1_pb0
		     &octospim_p1_io2_pa3 &octospim_p1_io3_pa1>;
	pinctrl-names = "default";
	status = "disabled";

	qspi_flash: qspi-nor-flash@0 {
		compatible = "st,stm32-ospi-nor";
		reg = <0 DT_SIZE_M(8)>;
		ospi-max-frequency = <DT_FREQ_M(80)>;
		spi-bus-width = <OSPI_QUAD_MODE>;
		data-rate = <OSPI_STR_TRANSFER>;
		writeoc = "PP_1_1_4";
		size = <DT_SIZE_M(64)>;
		status = "disabled";
	};
};

&dcmi {
	pinctrl-0 = <&dcmi_hsync_pa4 &dcmi_pixclk_pa6 &dcmi_vsync_pb7
		     &dcmi_d0_pc6 &dcmi_d1_pc7 &dcmi_d2_pc8 &dcmi_d3_pc9
		     &dcmi_d4_pe4 &dcmi_d5_pd3 &dcmi_d6_pe5 &dcmi_d7_pe6>;
	pinctrl-names = "default";
	status = "disabled";
};

&mco1 {
	clocks = <&rcc STM32_SRC_HSE MCO1_SEL(MCO1_SEL_HSE)>;
	clock-names = "clksel";
	prescaler = <MCO1_PRE(MCO_PRE_DIV_1)>;
	pinctrl-0 = <&rcc_mco_1_pa8>;
	pinctrl-names = "default";
	status = "disabled";
};

&rtc {
	clocks = <&rcc STM32_CLOCK(APB4, 16)>,
		 <&rcc STM32_SRC_LSI RTC_SEL(2)>;
	status = "okay";
};

&backup_sram {
	status = "okay";
};

&rng {
	status = "okay";
};
